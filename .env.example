# Anthropic API key - get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Cohere API key - get from https://dashboard.cohere.com/api-keys
COHERE_API_KEY=...

# Qdrant local (no key needed for local)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Model selection (defaults are fine to start)
CLAUDE_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=embed-multilingual-v3.0
RERANK_MODEL=rerank-multilingual-v3.0

# Collections
PUBLIC_COLLECTION=domiki_public
PRIVATE_COLLECTION=domiki_private
